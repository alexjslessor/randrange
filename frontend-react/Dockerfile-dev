FROM node:22-bullseye-slim

ARG VITE_PREFECT_API_URL
ARG VITE_AUTH_USER
# ARG LIFETIME_SECONDS
# ARG TIMEOUT
ENV VITE_PREFECT_API_URL=${VITE_PREFECT_API_URL} \
    VITE_AUTH_USER=${VITE_AUTH_USER}

# ENV VITE_LIFETIME_SECONDS=${VITE_LIFETIME_SECONDS}
# ENV VITE_TIMEOUT=${VITE_TIMEOUT}

WORKDIR /usr/src/app

COPY package*.json ./

CMD npm install --prefer-offline \
    && npm run dev